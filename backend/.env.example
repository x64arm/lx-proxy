# LX-Proxy Backend Environment Configuration

# 数据库连接
# Docker 环境：postgres://lx_proxy:lxproxy2026@db:5432/lx_proxy
# 本地开发：postgres://lx_proxy:lxproxy2026@localhost:5432/lx_proxy
DATABASE_URL=postgres://lx_proxy:lxproxy2026@db:5432/lx_proxy

# JWT 密钥（生产环境务必修改！）
# 生成方法：openssl rand -hex 32
JWT_SECRET=change_this_secret_key_in_production

# 日志级别：trace, debug, info, warn, error
RUST_LOG=info

# 服务器配置
HOST=0.0.0.0
PORT=3000

# Xray 配置
XRAY_PATH=/usr/local/bin/xray
XRAY_CONFIG_PATH=/etc/xray/config.json

# 会话配置（小时）
SESSION_TIMEOUT=24

# 安全配置
MAX_LOGIN_ATTEMPTS=5
IP_BAN_DURATION=60
