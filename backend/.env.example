# 数据库配置
DATABASE_URL=postgres://lx_proxy:lxproxy2026@localhost:5432/lx_proxy

# 服务器配置
HOST=0.0.0.0
PORT=8080

# JWT 配置
JWT_SECRET=lx-proxy-super-secret-key-change-in-production

# Xray 配置
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_BIN=/usr/local/bin/xray

# 基础 URL（用于生成订阅链接）
BASE_URL=http://localhost:8080

# 日志级别
RUST_LOG=lx_proxy_backend=debug,tower_http=debug
