# LX-Proxy Backend Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lx_proxy

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_HOURS=24

# Xray API Configuration
XRAY_API_URL=http://127.0.0.1:62780

# Email Notification Configuration (Optional)
# SMTP Server Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=LX-Proxy

# Email Notifications
# - Traffic alerts (when usage reaches 70%/90%)
# - Expiry reminders (before configuration expires)
# - Disabled notifications (when expired or over limit)
