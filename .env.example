# LX-Proxy Docker Environment Configuration
# 复制此文件为 .env 并根据实际情况修改

# ==================== 安全配置 ====================

# JWT 密钥（生产环境务必修改！）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# 数据库密码（生产环境建议修改）
DB_PASSWORD=lxproxy2026_secure_password

# ==================== 后端配置 ====================

# 日志级别：trace, debug, info, warn, error
RUST_LOG=info

# 后端服务端口
BACKEND_PORT=3000

# ==================== 前端配置 ====================

# 前端服务端口（宿主机映射）
FRONTEND_PORT=80

# HTTPS 端口（如启用）
HTTPS_PORT=443

# ==================== 数据库配置 ====================

# PostgreSQL 版本
POSTGRES_VERSION=15

# 数据库名称
POSTGRES_DB=lx_proxy

# 数据库用户
POSTGRES_USER=lx_proxy

# 数据持久化目录
POSTGRES_DATA_PATH=./data/postgres

# ==================== Xray 配置 ====================

# 是否启用 Xray 容器（true/false）
ENABLE_XRAY=false

# Xray 镜像版本
XRAY_IMAGE=ghcr.io/xtls/xray-core:latest

# ==================== 备份配置 ====================

# 是否启用自动备份（true/false）
ENABLE_BACKUP=false

# 备份时间（cron 格式，默认每天凌晨 3 点）
BACKUP_CRON=0 3 * * *

# 备份保留天数
BACKUP_RETENTION_DAYS=7
